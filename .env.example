NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. Required for public chat route handlers to create conversations under RLS.
SUPABASE_SERVICE_ROLE_KEY=

# Server-only Google Calendar OAuth. Do not prefix these with NEXT_PUBLIC_.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALENDAR_REDIRECT_URI=
# 32+ character secret used for AES-256-GCM token encryption.
GOOGLE_TOKEN_ENCRYPTION_KEY=

# Server-only AI provider key for Jonny public reservation assistant.
OPENAI_API_KEY=

# Server-only owner email alerts. Missing API key uses safe noop/failure behavior.
EMAIL_PROVIDER=
EMAIL_PROVIDER_API_KEY=
EMAIL_FROM_ADDRESS=
EMAIL_FROM_NAME=
APP_BASE_URL=http://localhost:3000

# Optional for full Playwright onboarding smoke.
E2E_OWNER_EMAIL=
E2E_OWNER_PASSWORD=
